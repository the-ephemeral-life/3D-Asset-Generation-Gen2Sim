xecution_count":9},{"cell_type":"code","source":"# ── Cell 6: Stage 1 — Background Removal ─────────────────────────\nfrom rembg import remove, new_session\nfrom PIL import Image\nimport numpy as np\nimport io as _io\nimport matplotlib.pyplot as plt\n\n\ndef remove_background_rembg(image_path: str, model_name: str = 'u2net') -> Image.Image:\n    \"\"\"\n    Remove background using rembg.\n    model_name options:\n      'u2net'               – general purpose, fast (~170 MB)\n      'isnet-general-use'   – higher quality, slower (~180 MB)\n      'birefnet-general'    – BiRefNet SOTA (~800 MB, needs ~4 GB VRAM)\n    \"\"\"\n    session = new_session(model_name)\n    with open(image_path, 'rb') as f:\n        raw = f.read()\n    result_bytes = remove(raw, session=session)\n    return Image.open(_io.BytesIO(result_bytes)).convert('RGBA')\n\n\ndef add_white_background(rgba_img: Image.Image) -> Image.Image:\n    \"\"\"Composite RGBA onto white — required by Zero123++.\"\"\"\n    bg = Image.new('RGBA', rgba_img.size, (255, 255, 255, 255))\n    bg.paste(rgba_img, mask=rgba_img.split()[3])\n    return bg.convert('RGB')\n\n\ndef center_and_pad(rgba_img: Image.Image, size: int = 512, margin: float = 0.8) -> Image.Image:\n    \"\"\"Center the object with margin to prevent 3D edge-clipping.\"\"\"\n    target_size = int(size * margin)\n    rgba_img.thumbnail((target_size, target_size), Image.LANCZOS)\n    padded = Image.new('RGBA', (size, size), (255, 255, 255, 0))\n    offset = ((size - rgba_img.width) // 2, (size - rgba_img.height) // 2)\n    padded.paste(rgba_img, offset)\n    return padded\n\n\nprint(f'Running background removal  model={BGS_MODEL} …')\nrgba_result  = remove_background_rembg(INPUT_IMAGE, BGS_MODEL)\nrgba_padded  = center_and_pad(rgba_result, size=512)\nrgb_white_bg = add_white_background(rgba_padded)\n\nrgba_path = str(OUTPUT_DIR / 'stage1_rgba.png')\nrgb_path  = str(OUTPUT_DIR / 'stage1_rgb_white.png')\nrgba_padded.save(rgba_path)\nrgb_white_bg.save(rgb_path)\n\nimg = Image.open(INPUT_IMAGE).convert('RGB')\nfig, axes = plt.subplots(1, 3, figsize=(12, 4))\nfor ax, im, title in zip(axes,\n                          [img, rgba_result, rgb_white_bg],\n                          ['Original', 'RGBA (no BG)', 'White BG (model input)']):\n    ax.imshow(im); ax.set_title(title); ax.axis('off')\nplt.tight_layout(); plt.show()\nprint(f'✅ Stage 1 complete → {rgba_path}')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T14:20:58.559232Z","iopub.execute_input":"2026-04-20T14:20:58.559595Z","iopub.status.idle":"2026-04-20T14:21:57.579132Z","shell.execute_reply.started":"2026-04-20T14:20:58.559565Z","shell.execute_reply":"2026-04-20T14:21:57.578322Z"}},"outputs":[{"name":"stderr","text":"Downloading data from 'https://github.com/danielgatis/rembg/releases/download/v0.0.0/isnet-general-use.onnx' to file '/root/.u2net/isnet-general-use.onnx'.\n","output_type":"stream"},{"name":"stdout","text":"Running background removal  model=isnet-general-use …\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"  0%|                                               | 0.00/179M [00:00<?, ?B/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"89b9772add794935ac47836def0f8ee2"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"<Figure size 1200x400 with 3 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"✅ Stage 1 complete → /kaggle/working/outputs/stage1_rgba.png\n","output_type":"stream"}],"execution_count":10},{"cell_type":"code","source":"# ── Cell 7: Stage 2 — Zero123++ Multi-View Generation ─────────────\n# FIX: Patch cached_download removed in huggingface_hub >= 0.26\nimport huggingface_hub as _hfhub\nif not hasattr(_hfhub, 'cached_download'):\n    _hfhub.cached_download = _hfhub.hf_hub_download\n\nimport torch, sys\nfrom diffusers import DiffusionPipeline, EulerAncestralDiscreteScheduler\nfrom PIL import Image\nimport matplotlib.pyplot as plt\n\nsys.path.insert(0, str(WORK_DIR / 'zero123plus'))\n\npipe = DiffusionPipeline.from_pretrained(\n    'sudo-ai/zero123plus-v1.2',\n    custom_pipeline=str(WORK_DIR / 'zero123plus' / 'diffusers-support' / 'pipeline.py'),\n    torch_dtype=torch.float16,\n)\npipe.scheduler = EulerAncestralDiscreteScheduler.from_config(\n    pipe.scheduler.config, timestep_spacing='trailing'\n)\npipe = pipe.to('cuda:0')\n\ninput_img = Image.open(rgb_path).resize((256, 256))\n\nprint(f'Generating 6 views  steps={DIFFUSION_STEPS} …')\nresult = pipe(input_img, num_inference_steps=DIFFUSION_STEPS).images[0]\n\n# Zero123++ returns a 3-row × 2-col grid (640 w × 960 h, each tile 320×320)\nview_paths = []\nfor row in range(3):\n    for col in range(2):\n        crop = result.crop((col * 320, row * 320, (col + 1) * 320, (row + 1) * 320))\n        vp   = str(OUTPUT_DIR / f'stage2_view_{row * 2 + col:02d}.png')\n        crop.save(vp)\n        view_paths.append(vp)\n\n# Visualise 3×2 grid\nfig, axes = plt.subplots(3, 2, figsize=(7, 10))\nfor ax, vp in zip(axes.flat, view_paths):\n    ax.imshow(Image.open(vp)); ax.axis('off')\nplt.suptitle('Stage 2 – Zero123++ Multi-View Output (6 views)')\nplt.tight_layout(); plt.show()\n\ndel pipe; torch.cuda.empty_cache()\nprint(f'✅ Stage 2 complete → {len(view_paths)} views saved to {OUTPUT_DIR}')\nprint()\nprint('Next steps:')\nprint('  1. Output tab → \"New Dataset\" → name it e.g. zero123-views')\nprint('  2. Open Notebook 2, Settings → Add Data → Your Datasets → attach it')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T14:22:09.366683Z","iopub.execute_input":"2026-04-20T14:22:09.366989Z","iopub.status.idle":"2026-04-20T14:23:40.671946Z","shell.execute_reply.started":"2026-04-20T14:22:09.366963Z","shell.execute_reply":"2026-04-20T14:23:40.671317Z"}},"outputs":[{"name":"stderr","text":"The cache for model files in Transformers v4.22.0 has been updated. Migrating your old cache. This is a one-time only operation. You