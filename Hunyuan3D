{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"pygments_lexer":"ipython3","nbconvert_exporter":"python","version":"3.6.4","file_extension":".py","codemirror_mode":{"name":"ipython","version":3},"name":"python","mimetype":"text/x-python"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[],"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":true}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"# ── Cell 1: Install Dependencies ─────────────────────────────────\n# Hunyuan3D-2 requires newer diffusers (>=0.30). This notebook intentionally\n# does NOT pin diffusers==0.27.2 — that lives in Notebook 1.\n\n# 1. System libraries needed by the custom CUDA rasterizer & OpenGL renderer\n!apt-get update -qq\n!apt-get install -y build-essential cmake ninja-build \\\n    libgl1-mesa-dev libgl1-mesa-glx xvfb -q\n\n# 2. Cap numpy below 2.0\n!pip install -q \"numpy<2.0.0\"\n\n# 3. Diffusion / HuggingFace stack — no version pins so pip resolves correctly\n!pip install -q diffusers accelerate transformers huggingface_hub xformers\n\n# 4. 3D utilities\n!pip install -q trimesh open3d PyMCubes einops omegaconf\n\n# 5. Force-reinstall pymeshlab against the fresh system GL libs\n!pip install -q --force-reinstall pymeshlab\n\nprint('✅ Base dependencies installed')\nprint('⚠️  DO NOT restart yet — run Cell 2 first to clone the repo, then restart.')","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ── Cell 2: Clone Hunyuan3D-2 & compile custom extensions ─────────\n# Run this BEFORE the kernel restart so the compiled .so files persist.\nimport os, subprocess\nfrom pathlib import Path\n\nWORK_DIR = Path('/kaggle/working')\nos.chdir(WORK_DIR)\n\n# -- Clone repo --\nif not (WORK_DIR / 'Hunyuan3D-2').exists():\n    subprocess.run(\n        ['git', 'clone', 'https://github.com/Tencent-Hunyuan/Hunyuan3D-2.git'],\n        check=True\n    )\n    print('✅ Hunyuan3D-2 cloned')\nelse:\n    print('Hunyuan3D-2 already present — skipping clone')\n\n# -- Install Python requirements (no diffusers pin inside this file) --\nsubprocess.run(\n    ['pip', 'install', '-q', '-r', 'Hunyuan3D-2/requirements.txt'],\n    check=True\n)\n\n# -- Compile custom CUDA rasterizer --\nrasterizer_dir = WORK_DIR / 'Hunyuan3D-2/hy3dgen/texgen/custom_rasterizer'\nprint('Compiling custom rasterizer …')\nsubprocess.run(['pip', 'install', '.'], cwd=rasterizer_dir, check=True)\nprint('✅ custom_rasterizer compiled')\n\n# -- Compile differentiable renderer --\ndiff_renderer_dir = WORK_DIR / 'Hunyuan3D-2/hy3dgen/texgen/differentiable_renderer'\nprint('Compiling differentiable renderer …')\nsubprocess.run(['pip', 'install', '.'], cwd=diff_renderer_dir, check=True)\nprint('✅ differentiable_renderer compiled')\n\nprint()\nprint('⚠️  NOW restart the kernel: Run → Restart & Clear Output, then continue from Cell 3')","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ── Cell 3: Verify Environment (run AFTER kernel restart) ─────────\nimport numpy as np\nimport torch\nimport diffusers, huggingface_hub\n\nprint(f'numpy          : {np.__version__}')           # must be 1.x\nprint(f'torch          : {torch.__version__}')\nprint(f'diffusers      : {diffusers.__version__}')    # should be >= 0.30\nprint(f'huggingface_hub: {huggingface_hub.__version__}')\nprint(f'CUDA           : {torch.cuda.is_available()}')\nif torch.cuda.is_available():\n    for i in range(torch.cuda.device_count()):\n        p = torch.cuda.get_device_properties(i)\n        print(f'  GPU {i}: {p.name}  {p.total_memory / 1e9:.1f} GB')","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ── Cell 4: Patch diffusers BasicTransformerBlock for Hunyuan3D ───\n# Hunyuan3D's texture pipeline reads .dim / .num_attention_heads /\n# .attention_head_dim / .dropout from BasicTransformerBlock instances.\n# These were removed in diffusers >= 0.28. We inject them as properties.\n\nimport diffusers.models.attention as _attn\n\n@property\ndef _dim(self):\n    return self.attn1.to_q.in_features\n\n@property\ndef _num_heads(self):\n    return self.attn1.heads\n\n@property\ndef _head_dim(self):\n    return self.attn1.to_q.in_features // self.attn1.heads\n\n@property\ndef _dropout(self):\n    return 0.0\n\n_attn.BasicTransformerBlock.dim                = _dim\n_attn.BasicTransformerBlock.num_attention_heads = _num_heads\n_attn.BasicTransformerBlock.attention_head_dim  = _head_dim\n_attn.BasicTransformerBlock.dropout             = _dropout\n\nprint('✅ BasicTransformerBlock properties patched')","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ── Cell 5: Copy unet sub-module files for diffusers naming convention ──\n# Hunyuan3D's HunyuanPaint UNet is a custom module inside hy3dgen/texgen/\n# hunyuanpaint/unet/. diffusers expects sibling files named unet.<module>.py.\n# We copy them once here so imports resolve correctly.\n\nimport os, shutil\nfrom pathlib import Path\n\nWORK_DIR   = Path('/kaggle/working')\nunet_dir   = WORK_DIR / 'Hunyuan3D-2/hy3dgen/texgen/hunyuanpaint/unet'\ntarget_dir = WORK_DIR / 'Hunyuan3D-2/hy3dgen/texgen/hunyuanpaint'\n\npatched = []\nfor fname in os.listdir(unet_dir):\n    if fname.endswith('.py'):\n        src = unet_dir / fname\n        dst = target_dir / f'unet.{fname}'\n        shutil.copy(src, dst)\n        patched.append(fname)\n\nprint(f'✅ Patched {len(patched)} files: {patched}')","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ── Cell 6: Paths & Config ────────────────────────────────────────\nfrom pathlib import Path\nimport os\n\n# ▶ CHANGE THIS to the slug of your published Notebook 1 output dataset\n# It appears as: /kaggle/input/<dataset-slug>/outputs/\nNB1_OUTPUT_DIR = Path('/kaggle/input/zero123-views/outputs')\n\nOUTPUT_DIR = Path('/kaggle/working/outputs')\nWORK_DIR   = Path('/kaggle/working')\nOUTPUT_DIR.mkdir(parents=True, exist_ok=True)\n\nrgb_path   = str(NB1_OUTPUT_DIR / 'stage1_rgb_white.png')\n\nprint(f'NB1 output dir : {NB1_OUTPUT_DIR}')\nprint(f'RGB white image: {rgb_path}  exists={os.path.exists(rgb_path)}')\nprint(f'Output dir     : {OUTPUT_DIR}')\n\n# Verify all 6 views are present\nview_paths = sorted(NB1_OUTPUT_DIR.glob('stage2_view_*.png'))\nassert len(view_paths) == 6, \\\n    f'Expected 6 stage2 views in {NB1_OUTPUT_DIR}, found {len(view_paths)}. ' \\\n    f'Make sure you attached the correct dataset.'\nprint(f'✅ Found {len(view_paths)} multi-view images')","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ── Cell 7: HuggingFace Login (required for tencent/Hunyuan3D-2) ──\n# Store your HF token in Kaggle Secrets (Add-ons → Secrets) as 'HF_TOKEN'\ntry:\n    from kaggle_secrets import UserSecretsClient\n    token = UserSecretsClient().get_secret('HF_TOKEN')\n    from huggingface_hub import login\n    login(token=token, add_to_git_credential=False)\n    print('✅ Logged in to HuggingFace')\nexcept Exception as e:\n    print(f'ℹ️  HF login skipped ({e}). If Hunyuan3D-2 download fails, add HF_TOKEN to Kaggle Secrets.')","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ── Cell 8: Stage 3a — Shape (Mesh) with Hunyuan3D-2MV ────────────\nimport sys, torch\nfrom PIL import Image\n\nsys.path.insert(0, str(WORK_DIR / 'Hunyuan3D-2'))\nfrom hy3dgen.shapegen import Hunyuan3DDiTFlowMatchingPipeline\n\n# Route to second GPU if available to reserve cuda:0 for texture later\nDEVICE_SHAPE = 'cuda:1' if torch.cuda.device_count() > 1 else 'cuda:0'\nprint(f'Shape pipeline device: {DEVICE_SHAPE}')\n\nprint('Loading Hunyuan3D-2MV shape pipeline …')\nshape_pipeline = Hunyuan3DDiTFlowMatchingPipeline.from_pretrained(\n    'tencent/Hunyuan3D-2mv',\n    subfolder='hunyuan3d-dit-v2-mv',\n    torch_dtype=torch.float16,\n    device=DEVICE_SHAPE,\n)\n\n# Load views from Notebook 1 output\nmv_images    = [Image.open(p) for p in view_paths]\nfront_image  = Image.open(rgb_path)\n\n# Map Zero123++ azimuths to Hunyuan's expected view keys:\n#   view 01 = azimuth  90° → right\n#   view 04 = azimuth 270° → left\ninput_views = {\n    'front': front_image,\n    'right': mv_images[1],\n    'left' : mv_images[4],\n}\n\nprint('Generating mesh …')\nwith torch.no_grad():\n    output = shape_pipeline(\n        image=input_views,\n        num_inference_steps=50,\n    )\n\n# Pipeline returns a list/tuple; first element is a trimesh.Trimesh\nmesh = output[0]\n\nobj_path = str(OUTPUT_DIR / 'stage3_mesh.obj')\nmesh.export(obj_path)\n\nprint(f'  Vertices : {len(mesh.vertices):,}')\nprint(f'  Faces    : {len(mesh.faces):,}')\nprint(f'✅ Shape done → {obj_path}')\n\ndel shape_pipeline\ntorch.cuda.empty_cache()","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ── Cell 9: Stage 3b — Texture with Hunyuan3D-2 Paint ─────────────\nfrom hy3dgen.texgen import Hunyuan3DPaintPipeline\n\nDEVICE_TEX = 'cuda:0'\nprint(f'Texture pipeline device: {DEVICE_TEX}')\n\nprint('Loading Hunyuan3D-2 texture pipeline …')\ntexture_pipeline = Hunyuan3DPaintPipeline.from_pretrained(\n    'tencent/Hunyuan3D-2',\n    subfolder='hunyuan3d-paint-v2-0',\n).to(device=DEVICE_TEX, dtype=torch.float16)\n\nprint('Painting texture …')\nwith torch.no_grad():\n    textured_mesh = texture_pipeline(\n        mesh=mesh,\n        image=front_image,\n    )\n\nglb_path = str(OUTPUT_DIR / 'stage3_mesh_textured.glb')\ntextured_mesh.export(glb_path)\n\ndel texture_pipeline\ntorch.cuda.empty_cache()\n\nprint(f'✅ Texture done → {glb_path}')","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ── Cell 10: 3D Mesh Preview & Final Export ────────────────────────\nimport trimesh\nimport numpy as np\nimport matplotlib.pyplot as plt\nfrom mpl_toolkits.mplot3d.art3d import Poly3DCollection\n\n# Reload from disk for a clean preview\npreview_mesh = trimesh.load(obj_path, force='mesh')\n\nprint(f'Vertices  : {len(preview_mesh.vertices):,}')\nprint(f'Faces     : {len(preview_mesh.faces):,}')\nprint(f'Bounds    : {preview_mesh.bounds}')\nprint(f'Watertight: {preview_mesh.is_watertight}')\n\nfig = plt.figure(figsize=(8, 6))\nax  = fig.add_subplot(111, projection='3d')\n\nidx  = np.random.choice(len(preview_mesh.faces),\n                         min(5000, len(preview_mesh.faces)), replace=False)\ntris = preview_mesh.vertices[preview_mesh.faces[idx]]\npoly = Poly3DCollection(tris, alpha=0.3, linewidth=0.1,\n                         edgecolor='#446688', facecolor='#88bbee')\nax.add_collection3d(poly)\n\nscale  = preview_mesh.vertices.max(axis=0) - preview_mesh.vertices.min(axis=0)\ncenter = (preview_mesh.vertices.max(axis=0) + preview_mesh.vertices.min(axis=0)) / 2\nax.set_xlim(center[0] - scale.max()/2, center[0] + scale.max()/2)\nax.set_ylim(center[1] - scale.max()/2, center[1] + scale.max()/2)\nax.set_zlim(center[2] - scale.max()/2, center[2] + scale.max()/2)\nax.set_title('Stage 3 — Reconstructed Mesh Preview')\nplt.tight_layout(); plt.show()\n\n# Also copy final GLB to a clearly named output file\nimport shutil\nfinal_glb = str(OUTPUT_DIR / 'final_mesh_textured.glb')\nshutil.copy(glb_path, final_glb)\n\nprint(f'\\n✅ All done!')\nprint(f'  Untextured OBJ        → {obj_path}')\nprint(f'  Textured GLB          → {final_glb}')\nprint('   Download from the Kaggle Output tab on the right ↗')","metadata":{"trusted":true},"outputs":[],"execution_count":null}]}