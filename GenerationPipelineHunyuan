ply":"2026-04-15T10:44:25.348294Z"}},"outputs":[{"name":"stdout","text":"The token has not been saved to the git credentials helper. Pass `add_to_git_credential=True` in this function directly or `--add-to-git-credential` if using via `huggingface-cli` if you want to set the git credential as well.\nToken is valid (permission: fineGrained).\nYour token has been saved to /root/.cache/huggingface/token\nLogin successful\n✅ Logged in to HuggingFace\n","output_type":"stream"}],"execution_count":3},{"cell_type":"code","source":"from rembg import remove, new_session\nfrom PIL import Image\nimport numpy as np\nimport io as _io\nimport matplotlib.pyplot as plt\n\n# rembg downloads model weights to ~/.u2net/ on first run (~170 MB for u2net)\n# On Kaggle this is /root/.u2net/ — it re-downloads each session unless you\n# cache it in a dataset. See the Tips cell at the bottom for how to do this.\n\ndef remove_background_rembg(image_path: str, model_name: str = 'u2net') -> Image.Image:\n    \"\"\"\n    Remove background using rembg.\n    model_name options:\n      'u2net'               – general purpose, fast (~170 MB)\n      'isnet-general-use'   – higher quality, slower (~180 MB)\n      'birefnet-general'    – BiRefNet SOTA (~800 MB, needs ~4 GB VRAM)\n    \"\"\"\n    session = new_session(model_name)\n    with open(image_path, 'rb') as f:\n        raw = f.read()\n    result_bytes = remove(raw, session=session)\n    return Image.open(_io.BytesIO(result_bytes)).convert('RGBA')\n\n\ndef add_white_background(rgba_img: Image.Image) -> Image.Image:\n    \"\"\"Composite RGBA onto white — required by Zero123++ / Hunyuan3D.\"\"\"\n    bg = Image.new('RGBA', rgba_img.size, (255, 255, 255, 255))\n    bg.paste(rgba_img, mask=rgba_img.split()[3])\n    return bg.convert('RGB')\n\n\ndef center_and_pad(rgba_img: Image.Image, size: int = 512, margin: float = 0.8) -> Image.Image:\n    \"\"\"Center the object with a forced margin to prevent 3D edge-clipping.\"\"\"\n    # Shrink the object to 80% of the canvas size\n    target_size = int(size * margin)\n    rgba_img.thumbnail((target_size, target_size), Image.LANCZOS)\n\n    # Paste it into the center of the full 512x512 canvas\n    padded = Image.new('RGBA', (size, size), (255, 255, 255, 0))\n    offset = ((size - rgba_img.width) // 2, (size - rgba_img.height) // 2)\n    padded.paste(rgba_img, offset)\n    return padded\n\n\nprint(f'Running background removal  model={BGS_MODEL} …')\nrgba_result  = remove_background_rembg(INPUT_IMAGE, BGS_MODEL)\nrgba_padded  = center_and_pad(rgba_result, size=512)\nrgb_white_bg = add_white_background(rgba_padded)\n\nrgba_path = str(OUTPUT_DIR / 'stage1_rgba.png')\nrgb_path  = str(OUTPUT_DIR / 'stage1_rgb_white.png')\nrgba_padded.save(rgba_path)\nrgb_white_bg.save(rgb_path)\n\n# Reload original for display\nimg = Image.open(INPUT_IMAGE).convert('RGB')\n\nfig, axes = plt.subplots(1, 3, figsize=(12, 4))\nfor ax, im, title in zip(axes,\n                          [img, rgba_result, rgb_white_bg],\n                          ['Original', 'RGBA (no BG)', 'White BG (model input)']):\n    ax.imshow(im); ax.set_title(title); ax.axis('off')\nplt.tight_layout(); plt.show()\nprint(f'✅ Stage 1 complete  →  {rgba_path}')\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-15T10:44:28.311238Z","iopub.execute_input":"2026-04-15T10:44:28.311947Z","iopub.status.idle":"2026-04-15T10:45:27.420723Z","shell.execute_reply.started":"2026-04-15T10:44:28.311916Z","shell.execute_reply":"2026-04-15T10:45:27.419937Z"}},"outputs":[{"name":"stderr","text":"Downloading data from 'https://github.com/danielgatis/rembg/releases/download/v0.0.0/isnet-general-use.onnx' to file '/root/.u2net/isnet-general-use.onnx'.\n","output_type":"stream"},{"name":"stdout","text":"Running background removal  model=isnet-general-use …\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"  0%|                                               | 0.00/179M [00:00<?, ?B/s]","application/v