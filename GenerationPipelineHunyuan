ution_count":7},{"cell_type":"code","source":"# ── Stage 3: Mesh Generation with Hunyuan3D-2MV ──────────────────\n# Uses the multi-view variant by mapping Zero123++ side profiles.\n# Shape-only (no texture) keeps VRAM under ~6 GB — well within T4 16 GB.\nimport sys, torch\nfrom PIL import Image\n\nsys.path.insert(0, str(WORK_DIR / 'Hunyuan3D-2'))\nfrom hy3dgen.shapegen import Hunyuan3DDiTFlowMatchingPipeline\n\n# Route to second GPU if available (frees cuda:0 for other stages)\nDEVICE_HY = 'cuda:1' if torch.cuda.device_count() > 1 else 'cuda:0'\nprint(f'Routing Hunyuan3D to: {DEVICE_HY}')\n\nprint('Loading Hunyuan3D-2MV (shape only) …')\npipeline = Hunyuan3DDiTFlowMatchingPipeline.from_pretrained(\n    'tencent/Hunyuan3D-2mv',\n    subfolder='hunyuan3d-dit-v2-mv',\n    torch_dtype=torch.float16,\n    device=DEVICE_HY,\n)\n\n# Load the 6 multi-view images produced by Zero123++ in Stage 2\nview_paths  = sorted(OUTPUT_DIR.glob('stage2_view_*.png'))\nassert len(view_paths) == 6, f'Expected 6 views, found {len(view_paths)}'\nmv_images   = [Image.open(p) for p in view_paths]\n\n# Front-view reference: white-bg image from Stage 1\nfront_image = Image.open(rgb_path)\n\n# --- THE FIX STARTS HERE ---\n# Map the available Zero123++ views to the explicit keys Hunyuan expects\ninput_views = {\n    \"front\": front_image,\n    \"right\": mv_images[1], # Zero123++ Azimuth 90°\n    \"left\": mv_images[4]   # Zero123++ Azimuth 270°\n}\n\nprint('Generating mesh …')\nwith torch.no_grad():\n    # Pass the dictionary directly to the `image` argument\n    output = pipeline(\n        image=input_views, \n        num_inference_steps=50,\n        output_type=\"trimesh\" # Ensures we get a Trimesh object out\n    )\n\n# The official pipeline returns a tuple where the trimesh is the first element\nmesh = output[0] \n# --- THE FIX ENDS HERE ---\n\nobj_path = str(OUTPUT_DIR / 'stage3_mesh.obj')\nglb_path = str(OUTPUT_DIR / 'stage3_mesh.glb')\nmesh.export(obj_path)\nmesh.export(glb_path)\n\ndel